# Squad (local planning infrastructure — not part of the app)
.squad/
.gitattributes

# Copilot
.copilot/

# GitHub workflows (Squad-generated, not part of app)
.github/
# ...except the actual deployment pipeline
!.github/
!.github/workflows/
!.github/workflows/deploy.yml
# Re-ignore Squad-generated workflows
.github/workflows/sync-squad-labels.yml
.github/workflows/squad-*.yml
.github/agents/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# Build-stamped version file (generated at deploy time by CI / scripts/stamp_version.sh)
src/_version.py

# Local dev state
.local_state.json
nws_freshness_metrics.jsonl

# Azure Functions
local.settings.json
.python_packages/
.funcignore

# IDE
.vscode/
*.swp
*.swo
.squad-workstream
.DS_Store

# Azurite (local Azure storage emulator)
AzuriteConfig
azurite-debug.log
__azurite_db_*
__blobstorage__/
__queuestorage__/
